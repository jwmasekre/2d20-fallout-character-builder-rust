  "query": "\n            SELECT t.id, ot.origin_id, t.name, t.description,\n                ot.is_ghoul_trait\n            FROM origin_traits ot\n            JOIN traits t ON t.id = ot.trait_id\n            WHERE ot.is_ghoul_trait = 1\n            ORDER BY ot.is_ghoul_trait, t.name\n            ",
